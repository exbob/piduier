[Unit]
Description=piduier monitor service
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=<prefix>/share/piduier
ExecStart=<prefix>/bin/piduier --config <prefix>/etc/piduier/piduier.conf
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
