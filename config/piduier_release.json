{
  "http_listen": "0.0.0.0",
  "http_port": 8000,
  "zlog": {
    "log_file": "./piduier.log",
    "global": {
      "strict init": "true",
      "default format": "\"%d(%F %T.%l) %-6V %m%n\""
    },
    "formats": {
      "ts": "\"%d(%F %T.%l) %-6V %m%n\""
    },
    "rules": [
      "piduier.=ERROR \"@LOG_FILE@\", 10MB * 5 ~ ; ts",
      "piduier.=INFO \"@LOG_FILE@\", 10MB * 5 ~ ; ts",
      "mongoose.=ERROR \"@LOG_FILE@\", 10MB * 5 ~ ; ts",
      "mongoose.=INFO \"@LOG_FILE@\", 10MB * 5 ~ ; ts"
    ]
  }
}
