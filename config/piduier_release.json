{
  "http_listen": "0.0.0.0",
  "http_port": 8000,
  "web_root": "./web",
  "pinctrl": {
    "gpio0": "ip",
    "gpio1": "ip",
    "gpio2": "a3",
    "gpio3": "a3",
    "gpio4": "no",
    "gpio5": "no",
    "gpio6": "no",
    "gpio7": "op",
    "gpio8": "op",
    "gpio9": "a0",
    "gpio10": "a0",
    "gpio11": "a0",
    "gpio12": "no",
    "gpio13": "no",
    "gpio14": "a4",
    "gpio15": "a4",
    "gpio16": "no",
    "gpio17": "no",
    "gpio18": "no",
    "gpio19": "no",
    "gpio20": "no",
    "gpio21": "no",
    "gpio22": "no",
    "gpio23": "no",
    "gpio24": "no",
    "gpio25": "no",
    "gpio26": "no",
    "gpio27": "no"
  },
  "zlog": {
    "log_file": "./piduier.log",
    "global": {
      "strict init": "true",
      "default format": "\"%d(%F %T.%l) %-6V %m%n\""
    },
    "formats": {
      "ts": "\"%d(%F %T.%l) %-6V %m%n\""
    },
    "rules": [
      "piduier.=ERROR \"@LOG_FILE@\", 10MB * 5 ~ ; ts",
      "piduier.=INFO \"@LOG_FILE@\", 10MB * 5 ~ ; ts",
      "mongoose.=ERROR \"@LOG_FILE@\", 10MB * 5 ~ ; ts",
      "mongoose.=INFO \"@LOG_FILE@\", 10MB * 5 ~ ; ts"
    ]
  }
}
